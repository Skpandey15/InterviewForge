{
  "title": "AIP — Platform & AI Quality",
  "uid": "aip-overview",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP request rate by service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP p95 latency by service",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "AI tokens consumed (rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(ai_tokens_total[5m])) * 60",
          "legendFormat": "{{operation}} tokens/min"
        }
      ]
    },
    {
      "id": 4,
      "title": "Interviewer turn duration p95",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ai_turn_duration_seconds_bucket[5m])))",
          "legendFormat": "turn p95"
        }
      ]
    },
    {
      "id": 5,
      "title": "Evaluations completed / groundedness",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(ai_evaluations_total[5m])) * 60",
          "legendFormat": "evaluations/min"
        },
        {
          "expr": "avg(ai_evaluation_groundedness)",
          "legendFormat": "avg groundedness (last)"
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM heap used",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Kafka listener throughput",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (job) (rate(spring_kafka_listener_seconds_count[5m])) * 60",
          "legendFormat": "{{job}} msgs/min"
        }
      ]
    }
  ]
}
